{
  "name": "auditlens",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build || (rm -rf .next && next build)",
    "build:clean": "rm -rf .next && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "smoke:ai": "tsx --test lib/ai-smoke.test.ts",
    "test:audit": "tsx --test server/audit-engine.test.ts",
    "test:langgraph": "tsx --test server/langgraph.test.ts",
    "test:report": "tsx --test server/report.test.ts",
    "test:rag": "tsx --test server/rag.test.ts",
    "seed:kb": "tsx scripts/seed-knowledge-base.ts",
    "codegraph:sync": "node scripts/codegraph-sync.mjs",
    "fixtures:xlsx": "node scripts/build-fixtures-xlsx.mjs",
    "postversion": "npm run codegraph:sync"
  },
  "dependencies": {
    "@langchain/core": "^1.2.0",
    "@langchain/langgraph": "^1.4.4",
    "@pinecone-database/pinecone": "^8.0.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.511.0",
    "next": "^15.3.3",
    "openai": "^6.44.0",
    "radix-ui": "^1.6.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.3.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.8",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "eslint": "^9.27.0",
    "eslint-config-next": "^15.3.3",
    "tailwindcss": "^4.1.8",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.3.4",
    "typescript": "^5.8.3"
  }
}
