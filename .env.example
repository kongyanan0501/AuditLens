# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# LLM — server-side only (never expose in client components)
# openai | qwen | deepseek (deepseek 尚未实现)
AI_PROVIDER=openai

# --- OpenAI (AI_PROVIDER=openai) ---
OPENAI_API_KEY=
# 可选：OpenAI 兼容代理（中国大陆访问官方 API 常需配置）
# OPENAI_BASE_URL=https://your-proxy.example/v1
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# --- 阿里云百炼 / 通义 Qwen (AI_PROVIDER=qwen，无需 OpenAI) ---
DASHSCOPE_API_KEY=
# 默认北京地域 OpenAI 兼容端点；国际站可改为 https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_CHAT_MODEL=qwen-plus
# 默认 text-embedding-v2（1536 维，与 Pinecone index 一致）
QWEN_EMBED_MODEL=text-embedding-v2
# 使用 text-embedding-v3/v4 时须指定 1536，与 Pinecone 维度匹配
# QWEN_EMBED_DIMENSIONS=1536

# Optional future provider
DEEPSEEK_API_KEY=

# Pinecone — server-side only
PINECONE_API_KEY=
PINECONE_INDEX=auditlens
